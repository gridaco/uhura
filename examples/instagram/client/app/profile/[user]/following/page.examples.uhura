use fixture standard

example loading {
  params { user = "user-lena" }
  projection feed.viewer = fixture.users.mira
}

example lena default {
  params { user = "user-lena" }
  projection feed.viewer = fixture.users.mira
  projection profile.following("user-lena") = fixture.people.lena-following
}

example mira {
  params { user = "user-mira" }
  projection feed.viewer = fixture.users.mira
  projection profile.following("user-mira") = fixture.people.mira-following
}
