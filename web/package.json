{
  "name": "@uhura/web-host",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": "24.x",
    "pnpm": "10.11.0"
  },
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "dev:provider": "vite build --watch --config vite.provider.config.ts",
    "typecheck": "tsc -b",
    "build": "pnpm run build:app && pnpm run build:export && pnpm run build:provider",
    "build:app": "vite build --config vite.config.ts",
    "build:export": "vite build --config vite.config.ts --mode export",
    "build:provider": "vite build --config vite.provider.config.ts",
    "lint": "pnpm run lint:web && pnpm run lint:provider",
    "lint:web": "oxlint --deny-warnings src *.config.ts",
    "lint:provider": "cd .. && web/node_modules/.bin/oxlint --deny-warnings -c web/.oxlintrc.json examples/instagram/client/providers/*.ts",
    "test": "vitest run",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run build && pnpm run test"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
